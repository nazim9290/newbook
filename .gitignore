# Dependencies
node_modules/

# Environment — never commit any local env file
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
# (NOTE: .env.example IS committed — it's the template, no real secrets)
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# Runtime / build artifacts
.pm2/
dist/
build/
coverage/
.nyc_output/

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Local DB dumps & backups (don't commit prod data)
*.sql.gz
*.dump
backups/
uploads/

# Test artifacts
tests/.env.test
