# =========================================================================
# AgencyBook Backend — Environment Variables Template
# =========================================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit .env, .env.local, or any file containing real secrets.
#
# Generate strong secrets with:
#   JWT_SECRET:       openssl rand -hex 64
#   ENCRYPTION_KEY:   openssl rand -hex 32   (must be exactly 64 hex chars)
# =========================================================================

# ---- Core (required) ----------------------------------------------------
NODE_ENV=development                  # development | production
PORT=5000                             # local: 5000, prod: 5002, dev-prod: 5001
DATABASE_URL=postgresql://user:password@localhost:5432/agencybook
JWT_SECRET=replace-with-openssl-rand-hex-64
ENCRYPTION_KEY=replace-with-openssl-rand-hex-32
CLIENT_URL=http://localhost:5173      # frontend origin for CORS
CORS_ORIGIN=http://localhost:5173     # alternative CORS list (comma-separated for multi)

# ---- Deployment / instance ----------------------------------------------
DEPLOYMENT_MODE=shared                # shared | dedicated | on-premise
INSTANCE_MODE=shared                  # shared (multi-tenant) | enterprise (single-tenant)
INSTANCE_ID=                          # set on dedicated/on-premise installs
LICENSE_STRICT=false                  # true = enforce license validity strictly

# ---- Storage ------------------------------------------------------------
STORAGE_BACKEND=local                 # local | r2 | mirror (write to both)
UPLOAD_DIR=./uploads                  # local fallback dir
UPLOADS_DIR=/home/agencybook/uploads  # VPS prod path
SKIP_UPLOADS_BACKUP=false             # true to exclude uploads from backup script

# ---- Mail (platform default; tenants can override via BYOK) -------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@agencybook.net
SMTP_FROM_NAME=AgencyBook
SMTP_REPLY_TO=
NOTIFY_FROM_EMAIL=noreply@agencybook.net
NOTIFY_FROM_NAME=AgencyBook
BREVO_API_KEY=                        # alternative transactional sender

# ---- AI / OCR (platform default; tenants can override via BYOK) ---------
ANTHROPIC_API_KEY=
GOOGLE_VISION_API_KEY=

# ---- Push notifications (Web Push / VAPID) ------------------------------
VAPID_PUBLIC_KEY=                     # generate: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@agencybook.net

# ---- Ops / heartbeat ----------------------------------------------------
OPS_EMAIL=ops@agencybook.net          # destination for ops alerts
OPS_HEARTBEAT_URL=                    # external healthcheck ping (e.g. uptime-kuma push URL)
TELEGRAM_BOT_TOKEN=                   # ops alert delivery via Telegram

# ---- Self-update channel (enterprise on-prem) ---------------------------
UPDATE_SERVER_URL=
UPDATE_SCRIPT_PATH=
