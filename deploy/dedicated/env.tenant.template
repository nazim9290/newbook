# ═══════════════════════════════════════════════════════════════════════
# Tier A — Dedicated cloud tenant .env template
# Rendered by scripts/provision-dedicated.sh — placeholders replaced.
# Final path on VPS:
#   /home/agencybook/instances/__SLUG__/.env
# Permissions: chmod 600, owner agencybook:agencybook
# ═══════════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=__PORT__

# ── Deployment identity (Phase 0 licensing layer reads these) ──
DEPLOYMENT_MODE=dedicated
INSTANCE_ID=__SLUG__
LICENSE_STRICT=false

# ── Database — isolated per tenant ──
DATABASE_URL=postgresql://agency___SLUG__:__DB_PASS__@127.0.0.1:5432/agencybook___SLUG__

# ── JWT (per-tenant secret — tokens not interchangeable across tenants) ──
JWT_SECRET=__JWT_SECRET__

# ── PII encryption key (AES-256, hex-encoded 32 bytes = 64 hex chars) ──
ENCRYPTION_KEY=__ENCRYPTION_KEY__

# ── CORS — accept tenant's frontend subdomain only ──
CORS_ORIGIN=https://__SLUG__.agencybook.net

# ── File uploads — isolated per tenant ──
UPLOAD_DIR=/home/agencybook/instances/__SLUG__/uploads
MAX_FILE_SIZE=10485760

# ── Sentry (shared central monitoring) ──
# DSN inherits from shared codebase config; release tag identifies tenant.
