{
  "name": "agency-os-backend",
  "version": "1.0.0",
  "description": "AgencyOS Study Abroad CRM — REST API backend",
  "main": "src/app.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@sentry/node": "^10.47.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "docx-templates": "^4.15.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.18",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testMatch": ["<rootDir>/tests/**/*.test.js"],
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": ["/node_modules/", "/tests/"],
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"]
  }
}
